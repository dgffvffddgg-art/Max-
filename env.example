# انسخ هذا الملف باسم .env واملأ القيم الخاصة بك
# لا ترفع ملف .env الحقيقي على GitHub أبداً!

# التوكن اللي هتاخده من @BotFather على تليجرام
BOT_TOKEN=هنا_حط_التوكن_بتاعك

# مدة الكتم بالدقايق بعد 3 تحذيرات (افتراضي: 60 دقيقة)
MUTE_DURATION_MINUTES=60

# مدة بقاء رسالة التحذير قبل ما تتمسح تلقائياً (بالثواني)
WARNING_MESSAGE_LIFETIME=15

# مفتاح Google Gemini المجاني (لاكتشاف الجدال حول الكورة/الدين/السياسة)
# احصل عليه مجاناً من: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# اسم موديل Gemini المستخدم (الافتراضي مجاني وسريع)
GEMINI_MODEL=gemini-2.0-flash
